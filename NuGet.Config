<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Isolate this repo from machine/User-level feeds (VS / dotnet global NuGet.Config).
       AxonFlow only needs public packages; private feeds often break restore with auth/VPN errors. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
